# Server port (default: 3000)
PORT=3000
# Database path (default: ./data/clawstash.db)
DATABASE_PATH=./data/clawstash.db
# Admin password for login (optional, if unset all admin features are open)
# ADMIN_PASSWORD=your-secret-password
# Admin session duration in hours (default: 24, 0 = no expiration)
# ADMIN_SESSION_HOURS=24
# Trust X-Forwarded-* headers from a reverse proxy (default: off).
# REQUIRED when behind nginx, Traefik, Cloudflare, etc. — otherwise
# rate limiting falls back to per-request random keys (no shared bucket,
# but no protection either) and OpenAPI / MCP spec URLs use the host
# header verbatim.
# TRUST_PROXY=1
# Encryption key for secrets stored at rest (GitHub backup token).
# 64 hex characters (32 bytes), e.g. from: openssl rand -hex 32
# Optional: when unset, a key file is auto-generated next to the database
# (data/.clawstash-key, mode 0600) — keep it with your data volume.
# CLAWSTASH_ENCRYPTION_KEY=

# --- Build-time env vars (CI/Docker only) -----------------------------
# Override the git information embedded into build-info.json. Set by the
# GitHub Actions workflow so the running container reports the commit
# that produced it, even though the image has no .git directory.
# BUILD_COMMIT_SHA=
# BUILD_BRANCH=
